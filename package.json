{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "nodemon src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate:create": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate create -m migrations --migration-file-language sql --migration-filename-format utc",
    "migrate:up": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate up -m migrations",
    "migrate:down": "node -r dotenv/config ./node_modules/node-pg-migrate/bin/node-pg-migrate down -m migrations",
    "migrate:status": "node -r dotenv/config scripts/migrate-status.js",
    "seed:development": "node -r dotenv/config scripts/run-seed.js development",
    "seed:test": "node -r dotenv/config scripts/run-seed.js test",
    "admin:create": "npm run build --silent && node dist/maintenance/adminCreate.cli.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/http-errors": "^2.0.5",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^24.0.7",
    "@types/nodemailer": "^6.4.17",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/supertest": "^7.2.1",
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@react-email/components": "^0.1.1",
    "@react-email/render": "^1.1.3",
    "argon2": "^0.44.0",
    "bcrypt": "^6.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.0",
    "magic-bytes.js": "^1.13.0",
    "mongoose": "^8.16.1",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "node-cron": "^4.2.0",
    "nodemailer": "^7.0.4",
    "path": "^0.12.7",
    "pg": "^8.22.0",
    "uuid": "^11.1.0",
    "zod": "^3.25.67"
  },
  "description": ""
}
