PORT=3001
NODE_ENV=development

# PostgreSQL
# Use this URL when running the backend directly on the host machine.
DATABASE_URL=postgres://points_review:points_review_password@localhost:5432/points_review

# Use this URL inside docker-compose services.
# DATABASE_URL=postgres://points_review:points_review_password@pr_b_postgres:5432/points_review

# Redis
# Use this URL when running the backend directly on the host machine.
REDIS_URL=redis://localhost:6379

# Use this URL inside docker-compose services.
# REDIS_URL=redis://pr_b_redis:6379

# Legacy MongoDB settings kept only while old routes are still present.
DATABASE=mongodb+srv://user:<db_password>@cluster.example.mongodb.net/database
DATABASE_PASSWORD=replace_me

# Legacy JWT settings kept only while old auth routes are still present.
JWT_ACCESS_SECRET=replace_me
JWT_REFRESH_SECRET=replace_me
JWT_RESET_SECRET=replace_me

# Email
EMAIL_USER=replace_me@example.com
EMAIL_PASS=replace_me

# Frontend
FRONTEND_URL=http://localhost:3000
